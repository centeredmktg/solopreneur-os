# --- Required ---
# Anthropic API key (pays for the Claude calls). Set in Railway, never commit.
ANTHROPIC_API_KEY=sk-ant-...

# --- Access gate (strongly recommended for any public deploy) ---
# If set, every /api/* call must send a matching X-App-Key header.
# The UI prompts for it once and stores it locally. Prevents bill abuse.
APP_KEY=choose-a-long-random-string

# --- Optional: model override (defaults to claude-sonnet-4-6) ---
# CLAUDE_MODEL=claude-opus-4-8

# --- Optional: Moxie integration (Task -> Time tool) ---
# From Moxie: Workspace Settings -> Connected Apps -> Integrations ->
# Enable Custom Integration. Copy the Base URL and API Key.
# MOXIE_BASE_URL=https://pod00.withmoxie.dev
# MOXIE_API_KEY=...
# Override only if the verified paths differ from the defaults:
# MOXIE_TIME_ENTRY_PATH=/api/public/timeentries/create
# MOXIE_TASK_PATH=/api/public/tasks/create
